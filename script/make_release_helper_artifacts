#!/usr/bin/env bash
#
# Build and package versioned remote-helper tarballs for GitHub Releases.
#
# Produces `ashide-<os>-<arch>.tar.gz` archives (each containing a single
# `ashide` binary) under target/release-artifacts/, and appends checksum lines
# to SHA256SUMS alongside the macOS app zip from make_release_artifacts.
#
# Usage:
#   script/make_release_helper_artifacts -c stable --release-tag v0.1.1
#
set -euo pipefail

WORKSPACE_ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ARTIFACTS_DIR="$WORKSPACE_ROOT_DIR/target/release-artifacts"
HELPER_TARGET_DIR="$WORKSPACE_ROOT_DIR/target/release-helper"
RELEASE_CHANNEL="stable"
RELEASE_TAG=""

while (( "$#" )); do
  case "$1" in
    -c|--channel)
      RELEASE_CHANNEL="$2"
      shift 2
      ;;
    --release-tag)
      RELEASE_TAG="$2"
      export GIT_RELEASE_TAG="$2"
      shift 2
      ;;
    *)
      echo "unknown arg: $1" >&2
      exit 1
      ;;
  esac
done

if [[ -z "$RELEASE_TAG" ]]; then
  echo "error: --release-tag is required" >&2
  exit 1
fi

case "$RELEASE_CHANNEL" in
  local|dev)
    CARGO_PROFILE="release-cli-debug_assertions"
    FEATURES="release_bundle,crash_reporting,standalone,agent_mode_debug"
    ;;
  stable|preview|oss)
    CARGO_PROFILE="release-cli"
    FEATURES="release_bundle,crash_reporting,standalone"
    ;;
  *)
    echo "error: unsupported channel $RELEASE_CHANNEL" >&2
    exit 1
    ;;
esac

mkdir -p "$ARTIFACTS_DIR"

package_helper() {
  local os="$1"
  local arch="$2"
  local binary_path="$3"
  local archive_name="ashide-${os}-${arch}.tar.gz"
  local staging
  staging="$(mktemp -d "${TMPDIR:-/tmp}/ashide-helper-staging.XXXXXX")"
  trap 'rm -rf "$staging"' RETURN

  if [[ ! -f "$binary_path" ]]; then
    echo "error: helper binary not found: $binary_path" >&2
    exit 1
  fi

  cp "$binary_path" "$staging/ashide"
  chmod 755 "$staging/ashide"
  tar -czf "$ARTIFACTS_DIR/$archive_name" -C "$staging" ashide

  (
    cd "$ARTIFACTS_DIR"
    if [[ -f SHA256SUMS ]]; then
      grep -v "  ${archive_name}\$" SHA256SUMS > SHA256SUMS.tmp || true
      mv SHA256SUMS.tmp SHA256SUMS
    fi
    shasum -a 256 "$archive_name" >> SHA256SUMS
  )

  echo "Wrote $ARTIFACTS_DIR/$archive_name"
}

build_linux_helper() {
  local rust_target="$1"
  local arch="$2"
  local output_dir="$HELPER_TARGET_DIR/$rust_target/$CARGO_PROFILE/ashide"

  echo "Building Linux helper for $rust_target (profile=$CARGO_PROFILE)"
  if command -v cargo-zigbuild >/dev/null 2>&1; then
    USE_ZIGBUILD=true CARGO_TARGET_DIR="$HELPER_TARGET_DIR" \
      cargo zigbuild -p warp --bin ashide --target "$rust_target" \
      --profile "$CARGO_PROFILE" --features "$FEATURES"
  else
    CARGO_TARGET_DIR="$HELPER_TARGET_DIR" \
      cargo build -p warp --bin ashide --target "$rust_target" \
      --profile "$CARGO_PROFILE" --features "$FEATURES"
  fi

  if [[ ! -f "$output_dir" ]]; then
    output_dir="$HELPER_TARGET_DIR/$rust_target/$CARGO_PROFILE/ashide"
  fi
  package_helper linux "$arch" "$output_dir"
}

build_macos_helper() {
  local arch
  arch="$(uname -m)"
  case "$arch" in
    arm64) arch="aarch64" ;;
    x86_64) arch="x86_64" ;;
    *)
      echo "error: unsupported macOS arch: $arch" >&2
      exit 1
      ;;
  esac

  local profile_dir="$CARGO_PROFILE"
  local binary_path="$WORKSPACE_ROOT_DIR/target/$profile_dir/ashide"
  if [[ ! -f "$binary_path" ]]; then
    echo "error: macOS helper binary not found at $binary_path; run:" >&2
    echo "  ./script/bundle --artifact cli --nosign --nouniversal -c $RELEASE_CHANNEL --release-tag $RELEASE_TAG" >&2
    exit 1
  fi

  package_helper macos "$arch" "$binary_path"
}

build_linux_helper x86_64-unknown-linux-musl x86_64
build_linux_helper aarch64-unknown-linux-musl aarch64

if [[ "$(uname -s)" == "Darwin" ]]; then
  build_macos_helper
fi

echo "Remote helper artifacts ready in $ARTIFACTS_DIR"
