#!/bin/bash
#
# linuxdeploy input plugin for restructuring the AppDir to match Ashide's
# standard Linux install layout.
#
# By default, linuxdeploy places the executable at usr/bin/ inside the AppDir.
# This plugin moves it to a directory tree that matches the deb/rpm/arch
# package install layout (controlled by ASHIDE_OPT_DIR), creates a symlink from
# usr/bin/ to the new location, and copies bundled resources alongside the
# binary.
#
# This means that extracting an AppImage produces the same filesystem layout
# as installing a .deb or .rpm package.
#
# Required environment variables:
#   ASHIDE_BINARY_NAME:         Name of the binary (e.g. "ashide").
#   ASHIDE_OPT_DIR:             Absolute /opt-rooted directory for the
#                               install layout inside the AppDir (e.g.
#                               "/opt/ashide" or "/opt/ashide-dev").
#   ASHIDE_BUNDLED_RESOURCES_DIR: Path to the staged resources directory to copy.

set -e

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --plugin-api-version)
      echo "0"
      exit 0
      ;;
    --appdir)
      APPDIR="$2"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [ -z "$APPDIR" ]; then
  echo "ERROR: --appdir is required" >&2
  exit 1
fi

for var in ASHIDE_BINARY_NAME ASHIDE_OPT_DIR ASHIDE_BUNDLED_RESOURCES_DIR; do
  if [ -z "${!var}" ]; then
    echo "ERROR: $var environment variable is not set" >&2
    exit 1
  fi
done

if [ ! -d "$ASHIDE_BUNDLED_RESOURCES_DIR" ]; then
  echo "ERROR: Bundled resources directory does not exist: $ASHIDE_BUNDLED_RESOURCES_DIR" >&2
  exit 1
fi

SRC_BIN="$APPDIR/usr/bin/$ASHIDE_BINARY_NAME"
if [ ! -f "$SRC_BIN" ]; then
  echo "ERROR: Expected binary not found at $SRC_BIN" >&2
  exit 1
fi

# Create the /opt install directory inside the AppDir. ASHIDE_OPT_DIR is an
# absolute path on the target machine (e.g. "/opt/ashide"); prepend the AppDir
# to nest it inside the AppImage.
OPT_DIR="$APPDIR$ASHIDE_OPT_DIR"
mkdir -p "$OPT_DIR"

# Move the binary from usr/bin/ to the OPT_DIR.
echo "Relocating binary to $OPT_DIR/$ASHIDE_BINARY_NAME"
mv "$SRC_BIN" "$OPT_DIR/$ASHIDE_BINARY_NAME"

# Create a relative symlink so usr/bin/<name> still resolves to the binary.
# usr/bin/<name> 的父目录是 usr/bin/,固定需要 ../../ 才能回到 AppDir 根,
# 然后拼上去掉前导 / 的 ASHIDE_OPT_DIR 与二进制文件名。
echo "Creating symlink at usr/bin/$ASHIDE_BINARY_NAME"
ln -s "../..${ASHIDE_OPT_DIR}/$ASHIDE_BINARY_NAME" "$SRC_BIN"

# Copy bundled resources alongside the binary.
DEST_RESOURCES="$OPT_DIR/resources"
echo "Copying bundled resources to $DEST_RESOURCES"
mkdir -p "$DEST_RESOURCES"
cp -R "$ASHIDE_BUNDLED_RESOURCES_DIR/." "$DEST_RESOURCES/"

echo "Successfully restructured AppDir for Ashide"
